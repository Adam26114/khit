# Khit E-Commerce Platform Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Convex Configuration
# ============================================
# Get this from your Convex dashboard after running `bunx convex dev`
CONVEX_DEPLOYMENT=your_convex_deployment_url_here
NEXT_PUBLIC_CONVEX_URL=your_convex_deployment_url_here

# ============================================
# Better Auth Configuration
# ============================================
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_here

# ============================================
# Sentry Configuration (Optional - setup later)
# ============================================
# Get these from Sentry dashboard after creating a project
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_ORG=your_sentry_org_slug
# SENTRY_PROJECT=khit-ecommerce

# ============================================
# Admin Configuration
# ============================================
# Initial admin email (set in Convex dashboard)
INITIAL_ADMIN_EMAIL=zweaungnaing26@gmail.com

# ============================================
# Store Configuration
# ============================================
STORE_NAME=Khit
STORE_CURRENCY=MMK
STORE_CURRENCY_SYMBOL=Ks
SHIPPING_FEE=2500
PICKUP_ADDRESS=Yangon
PICKUP_HOURS=Weekdays 9am - 4pm
